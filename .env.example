# Copy this file to .env and fill in values for local development
# Railway injects these automatically from its managed services

# Groq API (https://console.groq.com)
GROQ_API_KEY=

# Postgres — defaults below match the local docker-compose setup
PGHOST=localhost
PGPORT=5432
PGDATABASE=mudgame
PGUSER=mud
PGPASSWORD=mud
